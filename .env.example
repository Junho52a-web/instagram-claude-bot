# ===== Anthropic (Claude) =====
# Pegue em https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Modelo do Claude. Para atendimento, Haiku é rápido e barato.
# Opções: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ===== Instagram (API com Login do Instagram) =====
# Token de acesso gerado no app da Meta (começa com IGAA...)
IG_ACCESS_TOKEN=IGAAxxxxxxxxxxxxxxxxx

# ID da conta do Instagram (aparece ao lado da conta na tela "Gerar tokens")
IG_USER_ID=000000000000000

# Uma senha que VOCÊ inventa. Tem que ser igual à que você colocar no painel
# da Meta na hora de configurar o Webhook (campo "Verificar token").
VERIFY_TOKEN=minha-senha-secreta-123

# Versão da Graph API (pode deixar assim)
GRAPH_API_VERSION=v21.0

# ===== Servidor =====
PORT=3000
